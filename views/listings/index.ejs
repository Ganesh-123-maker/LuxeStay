<% layout("/layouts/boilerplate") %>

<div class="top-bar">

  <div class="search-bar">
    <span>Anywhere</span>
    <span>Any week</span>
    <span>Add guests</span>
    <span class="search-icon">
      <i class="fa-solid fa-magnifying-glass"></i>
    </span>
  </div>

  <div class="category-bar">

    <div class="categories-scroll">
      <div class="category active">
        <i class="fa-solid fa-city"></i>
        <p>City</p>
      </div>

      <div class="category">
        <i class="fa-solid fa-tree"></i>
        <p>Nature</p>
      </div>

      <div class="category">
        <i class="fa-regular fa-snowflake"></i>
        <p>Arctic</p>
      </div>

      <div class="category">
        <i class="fa-brands fa-fort-awesome"></i>
        <p>Castle</p>
      </div>

      <div class="category">
        <i class="fa-solid fa-ship"></i>
        <p>Boats</p>
      </div>

      <div class="category">
        <i class="fa-solid fa-water"></i>
        <p>Amazing pools</p>
      </div>
    </div>

    <div class="category-actions">
      <button class="filter-btn">
        <i class="fa-solid fa-sliders"></i> Filters
      </button>

      <div class="tax-toggle">
        <span>Display total after taxes</span>
        <input type="checkbox" id="flexSwitchCheckDefault">
      </div>
    </div>

  </div>

  <div class="search-box">
    <input type="text" id="searchInput" placeholder="Search listings...">
  </div>

</div>


<div class="row mt-4 justify-content-center g-4">
  <% for(let listing of allListings) { %>

    <div class="col-lg-4 col-md-6 col-sm-10 listing-item"
         data-title="<%= listing.title.toLowerCase() %>">

      <a href="/listings/<%= listing._id %>" class="listing-link">

        <div class="card listing-card">

          <div class="image-container">
            <img src="<%= listing.image.url %>" class="card-img-top">

            <div class="wishlist-icon">
              <i class="fa-regular fa-heart"></i>
            </div>
          </div>

          <div class="card-body">

            <div class="card-top">
              <h6 class="location">
                <%= listing.location %>, <%= listing.country %>
              </h6>
              <span class="rating">⭐ 4.8</span>
            </div>

            <p class="title"><%= listing.title %></p>

            <p class="price">
              ₹ <%= listing.price.toLocaleString("en-IN") %> / night
              <span class="tax-info"> +18% GST</span>
            </p>

          </div>

        </div>

      </a>

    </div>

  <% } %>
</div>


<script>
const taxSwitch = document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("click", () => {
  let taxInfo = document.getElementsByClassName("tax-info");
  for (let info of taxInfo) {
    info.style.display = info.style.display === "inline" ? "none" : "inline";
  }
});

const searchInput = document.getElementById("searchInput");
const items = document.querySelectorAll(".listing-item");

searchInput.addEventListener("input", () => {
  let val = searchInput.value.toLowerCase();

  items.forEach(item => {
    let title = item.dataset.title;
    item.style.display = title.includes(val) ? "block" : "none";
  });
});
</script>